{
  "name": "@golden-path/workflow-framework",
  "version": "0.1.0",
  "description": "Golden Path Workflow Framework — type-safe CDK constructs and CI/CD pipeline generators",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "test": "jest --passWithNoTests",
    "lint": "tsc --noEmit"
  },
  "keywords": ["golden-path", "devex", "cdk", "github-actions"],
  "license": "MIT",
  "peerDependencies": {
    "aws-cdk-lib": ">=2.100.0",
    "constructs": ">=10.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "aws-cdk-lib": "^2.168.0",
    "constructs": "^10.3.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "~5.3.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["test"],
    "testMatch": ["**/*.test.ts"]
  }
}
